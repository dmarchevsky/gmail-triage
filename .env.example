# ── Required ────────────────────────────────────────────────────────────────
# Encryption key for secrets at rest (Gmail token, Telegram token).
# Generate with: openssl rand -hex 32
# The app REFUSES TO START with an empty or default value.
APP_SECRET_KEY=

# Web UI password (single user). No auth-less mode exists.
UI_PASSWORD=

# PostgreSQL password for the bundled postgres service (docker compose).
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# Database URL. Compose sets this automatically to the bundled Postgres.
# Outside Docker, leave unset to use a local SQLite file under ./data.
# DATABASE_URL=postgresql+psycopg://mailtriage:<password>@localhost:5432/mailtriage

# ── LLM (llama.cpp or any OpenAI-compatible server) ────────────────────────
# Recommended: run llama.cpp on the host (e.g. Vulkan on AMD iGPU) and point
# this at it. host.docker.internal resolves to the host from the container.
LLM_BASE_URL=http://host.docker.internal:8081/v1
# Model name sent in requests; ignored by single-model llama.cpp servers.
LLM_MODEL=local

# ── Optional ────────────────────────────────────────────────────────────────
# Timezone for schedules and logs.
TZ=America/Los_Angeles
